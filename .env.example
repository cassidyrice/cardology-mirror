# Stripe — create three Products + Prices in your Stripe dashboard
# matching the $29 / $99 / $199 ladder, then paste the price IDs here.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx_for_29_dollar_basic_birth_card_report
STRIPE_PRICE_QUESTION=price_xxx_for_99_dollar_one_question_reading
STRIPE_PRICE_DEEP=price_xxx_for_199_dollar_full_deep_dive

# Email — Resend used for intake + webhook notifications.
# Verify a sending domain in Resend, then set INTAKE_FROM_EMAIL to that domain.
RESEND_API_KEY=re_xxx
INTAKE_EMAIL=cass@cardologypro.com
INTAKE_FROM_EMAIL=readings@cardologypro.com

# Site URL — used for Stripe success_url / cancel_url. Defaults to prod.
NEXT_PUBLIC_SITE_URL=https://cardologypro.com
